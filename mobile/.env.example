# Copia este fichero a .env.local y rellena los valores.
# Las EXPO_PUBLIC_* van al cliente y se incrustan en el bundle web.
# Las demás son secretos del lado servidor (Vercel env vars).

# --- Supabase ---
# Public URL del proyecto Supabase (frontend + API).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Anon key (segura para exponer al cliente).
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Service role key — SOLO en servidor (Vercel). Bypassa RLS, no exponer.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# --- Postgres directo ---
# Connection string del pool transaccional. Solo en servidor.
# Vercel: añadir como variable secreta. Local: opcional si solo trabajas el front.
DATABASE_URL=postgres://postgres.YOUR_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- Anthropic (OCR de facturas) ---
ANTHROPIC_API_KEY=sk-ant-...
# Override opcional del modelo (default: claude-opus-4-7).
ANTHROPIC_MODEL=claude-opus-4-7

# --- Same-origin / CORS ---
# Lista de orígenes permitidos por requireSameOrigin (coma-separados, sin espacios).
# Ya incluye lumotech.app, www.lumotech.app y *.vercel.app por defecto en código.
# ALLOWED_ORIGINS=https://lumotech.app,https://www.lumotech.app

# --- Legacy (no usar) ---
# API_SHARED_SECRET ya no se exige; el middleware real es Supabase JWT.
# API_SHARED_SECRET=
